# Optional overrides for `docker compose`. Copy to `.env` to customize; sensible
# dev defaults apply when absent, so `docker compose up --build` works with no
# setup. NEVER commit a real `.env` (it is gitignored) — no committed secrets.

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ticketing

# --- Backend ---
# A long random string, unique per environment. The compose default is a dev
# placeholder only — set a real value for any non-local deployment.
SESSION_SECRET=change-me-in-production

# Where you open the app in the browser; used to build email verification links.
APP_BASE_URL=http://localhost:8080
