# Backend configuration. Copy to `.env` for local runs; docker compose injects
# these directly. NEVER commit a real `.env` (it is gitignored) — no secrets in
# source control (PROJECT_RULES §Security).

# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
# Local (host) dev points at the compose `db` service published on 127.0.0.1.
# Use 127.0.0.1 (not `localhost`) so Node does not resolve to IPv6 ::1, which the
# published container port does not bind. Inside compose, the backend instead
# uses host `db` (e.g. postgres://postgres:postgres@db:5432/ticketing).
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ticketing

# --- Sessions ---
# Long random string. Generate one per environment; do not reuse this sample.
SESSION_SECRET=change-me-in-every-environment
# Set to `true` only behind HTTPS (production). Cookies are httpOnly + SameSite=Lax.
COOKIE_SECURE=false

# --- App URL (used to build verification links) ---
APP_BASE_URL=http://localhost

# --- SMTP (email verification) ---
# In docker compose, defaults target the Mailpit dev sink (host `mailpit`).
# Production must support relay1.dataart.com — set these accordingly.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@ticketing.local
